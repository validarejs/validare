{
  "name": "@validare/core",
  "version": "3.0.0",
  "description": "Modern JavaScript form validation library — plugin-based, zero dependencies, TypeScript-first",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^29.1.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "form",
    "validation",
    "validator",
    "typescript",
    "plugin",
    "form-validation",
    "html-form",
    "frontend"
  ],
  "author": "Vinicius <vinicius.big@gmail.com>",
  "homepage": "https://validarejs.github.io/validare-docs/",
  "repository": {
    "type": "git",
    "url": "https://github.com/validarejs/validare.git"
  },
  "bugs": {
    "url": "https://github.com/validarejs/validare/issues"
  },
  "license": "MIT"
}
